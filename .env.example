# CredSight environment — copy to .env and fill. NEVER commit .env.
# Challenge build is synthetic/sandbox only: no real PII, no real money movement.

# --- LLM (orchestration, reconciliation reasoning, explanation — never scoring) ---
ANTHROPIC_API_KEY=
CREDSIGHT_MODEL_ROUTING=anthropic:claude-haiku-4-5-20251001
CREDSIGHT_MODEL_REASONING=anthropic:claude-sonnet-4-6

# --- Connector mode: per-connector flip between synthetic and sandbox ---
# Allowed: synthetic | sandbox
CREDSIGHT_ADAPTER_AA=synthetic
CREDSIGHT_ADAPTER_GST=synthetic
CREDSIGHT_ADAPTER_UPI=synthetic
CREDSIGHT_ADAPTER_EPFO=synthetic
CREDSIGHT_ADAPTER_BUREAU=synthetic
CREDSIGHT_ADAPTER_OCEN=synthetic
CREDSIGHT_ADAPTER_LOS=synthetic

# --- IDBI sandbox API base URLs (filled on shortlist; unused in synthetic mode) ---
IDBI_SANDBOX_BASE_URL=
IDBI_SANDBOX_API_KEY=

# --- Decisioning ---
CREDSIGHT_SCORE_MODEL_VERSION=v0
# Knowledge brain backend:
#   lexical  (default) — dependency-free incremental lexical indexer
#   pgvector           — real semantic retrieval (sentence-transformers + pgvector store,
#                        cocoindex-memoized incremental embedding); needs the knowledge extra
CREDSIGHT_KNOWLEDGE_BACKEND=lexical
# pgvector backend (dedicated project Postgres container on 5433):
CREDSIGHT_KNOWLEDGE_DB_URL=postgresql://credsight:credsight@localhost:5433/credsight
CREDSIGHT_EMBEDDING_MODEL=all-MiniLM-L6-v2
# HITL interrupt thresholds (the parameter that shapes autonomy — see PRD §17)
CREDSIGHT_HITL_AMOUNT_THRESHOLD=200000
CREDSIGHT_HITL_CONFIDENCE_FLOOR=0.5

# --- Storage ---
DATABASE_URL=postgresql://localhost:5432/credsight
CREDSIGHT_DATA_DIR=./data/synthetic

# --- Observability (optional) ---
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=credsight
