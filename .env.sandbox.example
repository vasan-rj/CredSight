# CredSight — Sandbox environment template
# Copy to .env and fill in real values to switch from synthetic to IDBI sandbox connectors.
# All fields are optional: unset connectors default to synthetic mode (safe default).

# ── Per-connector adapter mode ────────────────────────────────────────────────
# Values: synthetic (default, no network) | sandbox (calls IDBI sandbox APIs below)

CREDSIGHT_ADAPTER_AA=sandbox        # Account Aggregator — bank statements
CREDSIGHT_ADAPTER_GST=sandbox       # GST returns (GSTR-3B)
CREDSIGHT_ADAPTER_UPI=synthetic     # UPI — sandbox endpoint not yet confirmed
CREDSIGHT_ADAPTER_EPFO=synthetic    # EPFO — sandbox endpoint not yet confirmed
CREDSIGHT_ADAPTER_BUREAU=synthetic  # Bureau — commercial license required

# ── IDBI sandbox credentials ──────────────────────────────────────────────────
# Provided by IDBI post-shortlist. Required when any adapter above is set to sandbox.

IDBI_SANDBOX_BASE_URL=https://sandbox.idbi.co.in/api/v1
IDBI_SANDBOX_API_KEY=your-api-key-here

# ── Orchestration ─────────────────────────────────────────────────────────────
# HITL gate fires when amount > threshold OR recommendation == reject OR confidence < floor.
# Set to 0 to route all cases through human review; raise to let more auto-flow.

CREDSIGHT_HITL_AMOUNT_THRESHOLD=600000      # loans > ₹6 lakh need human sign-off
CREDSIGHT_HITL_CONFIDENCE_FLOOR=0.70        # below this confidence → human review

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
# GBrain + CocoIndex state live here. Defaults shown for local Docker setup.

DATABASE_URL=postgresql://credsight:credsight@localhost:5433/credsight

# ── Observability ─────────────────────────────────────────────────────────────
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your-langsmith-key-here
LANGCHAIN_PROJECT=credsight-sandbox

# ── Model ─────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your-anthropic-key-here
